# Copy to .env and fill in real values. .env is gitignored.

# beehiiv API — used by skills/beehiiv-api
# Generate at: beehiiv dashboard -> Settings -> Integrations -> API
BEEHIIV_API_KEY=

# Find via: curl -H "Authorization: Bearer $BEEHIIV_API_KEY" https://api.beehiiv.com/v2/publications
BEEHIIV_PUB_ID=

# YouTube Data API v3 — used by skills/youtube-api (public data only, read-only)
# Generate at: https://console.cloud.google.com/ -> create project -> enable "YouTube Data API v3" -> create API key
YOUTUBE_API_KEY=

# Find via search: ./scripts/youtube.sh raw /search "part=snippet&q=<channel-name>&type=channel&maxResults=5"
# Or: if you own the channel, check YouTube Studio -> Settings -> Channel -> Advanced
YOUTUBE_CHANNEL_ID=
